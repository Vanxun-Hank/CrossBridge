+
+/* Markdown Styling */
+.message-content p { margin-bottom: 1.2em; }
+.message-content p:last-child { margin-bottom: 0; }
+
+.message-content pre {
+    background: var(--bg-tertiary);
+    border: 1px solid var(--border-color);
