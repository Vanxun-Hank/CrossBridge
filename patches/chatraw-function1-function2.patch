+# A just-restarted upstream leaves stale keep-alive connections in the shared aiohttp pool;
+# the first reuse fails with ServerDisconnectedError/ClientOSError. Retry once on those so an
+# upstream restart doesn't surface to users as a 502 (the cause of the saved-drafts 502).
+_PROXY_STALE_ERRORS = (
+    aiohttp.ServerDisconnectedError,
+    aiohttp.ClientConnectorError,
+    aiohttp.ClientOSError,
+)
+
+
+async def _proxy_pass(target_url: str, request: Request, *, unavailable_msg: str):
+    body = await request.body()
+    headers = {"Content-Type": request.headers.get("content-type", "application/json")}
+    last_exc = None
+    for attempt in range(2):
+        try:
+            session = await get_http_session()
+            async with session.request(
+                request.method,
+                target_url,
+                data=body,
+                headers=headers,
+                timeout=aiohttp.ClientTimeout(total=30),
+            ) as resp:
+                content = await resp.read()
+                return Response(
+                    content=content,
+                    status_code=resp.status,
+                    media_type=resp.headers.get("Content-Type", "application/json"),
+                )
+        except _PROXY_STALE_ERRORS as e:
+            last_exc = e
+            logger.warning("CrossBridge proxy stale-connection retry %d/2 (%s): %s", attempt + 1, target_url, e)
+            continue
+        except aiohttp.ClientError as e:
+            last_exc = e
+            break
+    logger.error("CrossBridge proxy failed (%s): %s", target_url, last_exc)
+    return JSONResponse({"error": unavailable_msg}, status_code=502)
+
+
+@app.api_route("/api/crossbridge/{path:path}", methods=["GET", "POST", "PATCH", "DELETE"])
+async def proxy_crossbridge_business_api(path: str, request: Request):
+    """Proxy only the fixed local CrossBridge business service; callers cannot choose a target."""
+    base_url = os.environ.get("CROSSBRIDGE_BUSINESS_API_URL", "http://127.0.0.1:8081").rstrip("/")
+    target_url = f"{base_url}/crossbridge/{path}"
+    if request.url.query:
+        target_url += f"?{request.url.query}"
+    return await _proxy_pass(
+        target_url, request, unavailable_msg="CrossBridge business service is unavailable"
+    )
+
+@app.api_route("/api/crossbridge-documents/{path:path}", methods=["GET", "POST", "PATCH", "DELETE"])
+async def proxy_crossbridge_documents_api(path: str, request: Request):
+    """Proxy only the fixed local CrossBridge document-preparation service (Function 2).
+
+    Parallel to the Function 1 business proxy above; callers cannot choose a target.
+    Fixed target is the F2 FastAPI service on port 8082.
+    """
+    base_url = os.environ.get("CROSSBRIDGE_DOCUMENTS_API_URL", "http://127.0.0.1:8082").rstrip("/")
+    target_url = f"{base_url}/crossbridge-documents/{path}"
+    if request.url.query:
+        target_url += f"?{request.url.query}"
+    return await _proxy_pass(
+        target_url, request, unavailable_msg="CrossBridge documents service is unavailable"
+    )
+
+# NOTE: this streaming route is declared BEFORE the catch-all timeline proxy below so it
+# wins route matching for GET /api/crossbridge-timeline/v1/events (the catch-all would
+# otherwise capture it and buffer the SSE stream).
+@app.get("/api/crossbridge-timeline/v1/events")
+async def proxy_crossbridge_timeline_events(request: Request):
+    """Stream the Function 3 SSE timeline feed to the SME without buffering.
+
+    The generic CrossBridge proxy buffers the whole response (``await resp.read()``),
+    which would stall an SSE stream forever. This dedicated route forwards chunks as
+    they arrive and sets ``X-Accel-Buffering: no`` so nginx does not buffer it either —
+    letting the SME's EventSource use one same-origin URL in both dev and prod.
+    """
+    base_url = os.environ.get("CROSSBRIDGE_TIMELINE_API_URL", "http://127.0.0.1:8083").rstrip("/")
+    target_url = f"{base_url}/crossbridge-timeline/v1/events"
+    if request.url.query:
+        target_url += f"?{request.url.query}"
+
+    async def event_stream():
+        try:
+            session = await get_http_session()
+            async with session.get(
+                target_url, timeout=aiohttp.ClientTimeout(total=None, sock_read=None)
+            ) as resp:
+                async for chunk in resp.content.iter_any():
+                    yield chunk
+        except aiohttp.ClientError as e:
+            logger.warning("CrossBridge timeline SSE proxy ended (%s): %s", target_url, e)
+            return
+
+    return StreamingResponse(
+        event_stream(),
+        media_type="text/event-stream",
+        headers={"Cache-Control": "no-cache", "X-Accel-Buffering": "no"},
+    )
+
+@app.api_route("/api/crossbridge-timeline/{path:path}", methods=["GET", "POST", "PATCH", "DELETE"])
+async def proxy_crossbridge_timeline_api(path: str, request: Request):
+    """Proxy only the fixed local CrossBridge application-timeline service (Function 3).
+
+    Parallel to the F1/F2 proxies; callers cannot choose a target. Fixed target is the
+    F3 FastAPI service on port 8083. SSE has the dedicated streaming route above; normal
+    reads/writes (create / list / get applications) use this buffered proxy.
+    """
+    base_url = os.environ.get("CROSSBRIDGE_TIMELINE_API_URL", "http://127.0.0.1:8083").rstrip("/")
+    target_url = f"{base_url}/crossbridge-timeline/{path}"
+    if request.url.query:
+        target_url += f"?{request.url.query}"
+    return await _proxy_pass(
+        target_url, request, unavailable_msg="CrossBridge timeline service is unavailable"
+    )
+
