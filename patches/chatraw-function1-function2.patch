+    padding: 0;
+    color: var(--text-primary);
+}
+
+/* Markdown Tables */
+.message-content table {
+    width: 100%;
+    border-collapse: collapse;
+    margin: 20px 0;
+    font-size: 0.95em;
+}
+
+.message-content table thead {
