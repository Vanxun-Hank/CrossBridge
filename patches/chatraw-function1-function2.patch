+                this.loanMatching.clarifyLoading = false;
+            }
+        },
+
+        // "匹配候选方案" on the inline draft card → run match, append product cards.
+        async runLoanMatchInline() {
+            if (!await this.saveLoanDraft(true) || !this.loanMatching.session?.ready_to_match) return;
+            this.loanMatching.matchLoading = true;
+            try {
+                const res = await fetch(`/api/crossbridge/v1/loan-matching/sessions/${this.loanMatching.session.id}/match`, { method: 'POST' });
+                const data = await res.json();
+                if (!res.ok) throw new Error(data.detail?.message || data.detail || this.t('cbMatchFailed'));
+                this.syncLoanMatchingSession(data);
+                if (data.match_results && data.match_results.length) {
+                    this.messages.push({ role: 'assistant', loanResults: data.match_results });
+                } else {
+                    // No product covers this exact scenario+purpose+amount — explain and
+                    // re-offer the editable draft so the user can adjust (e.g. financing purpose).
+                    this.messages.push({ role: 'assistant', content: this.t('cbNoMatch') });
+                    this.messages.push({ role: 'assistant', loanDraft: true });
+                }
+                this.$nextTick(() => this.scrollToBottom());
+            } catch (e) {
+                this.showToast(`${this.t('cbMatchFailed')}: ${e.message}`, 'error');
+            } finally {
+                this.loanMatching.matchLoading = false;
+            }
+        },
+
+        // "取消本次匹配" on the inline draft card → discard (truly abandon).
+        async cancelLoanMatchingInline() {
+            if (this.loanMatching.session) {
+                try {
+                    await fetch(`/api/crossbridge/v1/loan-matching/sessions/${this.loanMatching.session.id}/discard`, { method: 'POST' });
+                } catch (e) { console.warn('Failed to discard loan-matching draft:', e); }
+            }
+            this.loanMatching.session = null;
+            this.loanMatching.active = false;
