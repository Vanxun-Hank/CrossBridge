+    gap: 10px;
+}
+.dashboard-summary-grid article {
+    min-width: 0;
+    padding: 12px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-sm);
+    background: var(--bg-secondary);
+}
+.dashboard-summary-grid span {
+    display: block;
+    min-height: 32px;
+    font-size: 0.78rem;
+    line-height: 1.35;
+    color: var(--text-secondary);
+}
+.dashboard-summary-grid strong {
+    display: block;
+    margin-top: 8px;
+    font-size: 1.35rem;
+    line-height: 1;
+    color: var(--text-primary);
+}
+.dashboard-issues {
+    display: grid;
+    gap: 8px;
+}
+.dashboard-issues p {
+    display: flex;
+    gap: 8px;
+    margin: 0;
+    padding: 9px 10px;
+    border-radius: var(--radius-sm);
+    background: var(--bg-secondary);
+    color: var(--text-secondary);
+    font-size: 0.84rem;
+}
+.dashboard-issues strong {
+    color: var(--text-primary);
+}
+.dashboard-card-list {
+    display: grid;
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+    gap: 10px;
+}
+.dashboard-card-list-compact {
+    grid-template-columns: 1fr;
+}
+.dashboard-item-card {
+    min-width: 0;
+    padding: 12px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-sm);
+    background: var(--bg-secondary);
+}
+.dashboard-item-card h4 {
+    margin: 0 0 8px;
+    font-size: 0.94rem;
+    line-height: 1.35;
+    color: var(--text-primary);
+}
+.dashboard-item-card a {
+    color: inherit;
+    text-decoration: none;
+}
+.dashboard-item-card a:hover {
+    text-decoration: underline;
+}
+.dashboard-item-card p {
+    margin: 0 0 8px;
+    color: var(--text-secondary);
+    font-size: 0.84rem;
+    line-height: 1.45;
+}
+.dashboard-pill {
+    flex-shrink: 0;
+    padding: 2px 8px;
+    border-radius: 999px;
+    background: var(--bg-hover);
+    color: var(--text-secondary);
+    font-size: 0.76rem;
+    white-space: nowrap;
+}
+.dashboard-pill.ready {
+    color: var(--on-accent);
+    background: var(--accent-color);
+}
+.dashboard-policy-form {
+    display: grid;
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+    gap: 9px;
+    margin-bottom: 12px;
+}
+.dashboard-policy-form input {
+    width: 100%;
+    min-width: 0;
+    padding: 9px 10px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-sm);
+    color: var(--text-primary);
+    background: var(--bg-primary);
+}
+.dashboard-policy-form button {
+    justify-content: center;
+}
+.dashboard-policy-card {
+    align-items: center;
+}
+.dashboard-policy-card > div {
+    min-width: 0;
+}
+
+@media (max-width: 820px) {
+    .dashboard-modal {
+        width: 96vw;
+        max-height: 90vh;
+    }
+    .dashboard-header,
+    .dashboard-toolbar {
+        padding-left: 14px;
+        padding-right: 14px;
+    }
+    .dashboard-body {
+        padding: 14px;
+    }
+    .dashboard-summary-grid,
+    .dashboard-card-list,
+    .dashboard-policy-form {
+        grid-template-columns: 1fr;
+    }
+    .dashboard-policy-card,
+    .dashboard-item-row {
+        flex-direction: column;
+        align-items: flex-start;
+    }
+}
+
+/* ===== Function 3 — application progress timeline =====
+   Native to ChatRaw's minimal monochrome system: system font, white/grey/black tokens,
+   reuses the F2 panel/header/card chrome (.doc-prep-*) so it reads as the same app.
+   Status is restrained (ink + grey; ChatRaw's --destructive only for rejected) — no
+   rainbow badges. The only F3-local token is a faint theme-aware focus ring. */
+:root { --timeline-ring: rgba(0, 0, 0, 0.07); }
+[data-theme="dark"] { --timeline-ring: rgba(255, 255, 255, 0.09); }
+
+.timeline-empty { padding: 40px 8px; text-align: center; }
+
+/* status — quiet text + a small dot, single accent only where it carries meaning */
+.timeline-status {
+    font-size: 12px; font-weight: 500; color: var(--text-secondary);
+    white-space: nowrap; display: inline-flex; align-items: center; gap: 6px;
+}
+.timeline-status::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
+.timeline-status.tl-in_progress { color: var(--text-primary); }
+.timeline-status.tl-completed { color: var(--text-muted); }
+.timeline-status.tl-rejected { color: var(--error-color); }
+.timeline-status.tl-supplement_required { color: var(--text-secondary); }
+
+/* head card (sits inside a .doc-prep-card): product + id + progress line */
+.timeline-head { display: flex; flex-direction: column; gap: 9px; }
+.timeline-head-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
+.timeline-product { margin: 0; font-size: 16px; font-weight: 600; line-height: 1.3; color: var(--text-primary); }
+.timeline-sub { display: flex; align-items: center; justify-content: space-between; gap: 10px; font-size: 12px; color: var(--text-muted); }
+.timeline-id, .timeline-step { font-variant-numeric: tabular-nums; letter-spacing: .02em; }
+.timeline-progress { height: 3px; border-radius: 999px; background: var(--bg-tertiary); overflow: hidden; }
+.timeline-progress-fill { display: block; height: 100%; background: var(--accent-color); border-radius: 999px; transition: width .5s cubic-bezier(.2,.7,.2,1); }
+.timeline-progress-fill.tl-rejected { background: var(--error-color); }
+
+.timeline-switcher { margin-bottom: 14px; }
+
+/* ---- stepper ---- */
+.timeline-nodes { list-style: none; margin: 0; padding: 0; }
+.timeline-node { position: relative; display: grid; grid-template-columns: 16px 1fr; gap: 0 13px; padding: 0 0 18px; }
+.timeline-node:last-child { padding-bottom: 0; }
+.timeline-node::before { content: ''; position: absolute; left: 8px; top: 17px; bottom: 0; width: 1.5px; background: var(--border-color); transform: translateX(-50%); transition: background .3s ease; }
+.timeline-node:last-child::before { display: none; }
+/* completed steps fill the connector spine in ink — the journey travelled so far reads at a glance */
+.timeline-node.tl-completed::before { background: var(--accent-color); }
+.timeline-node-marker {
+    position: relative; z-index: 1; margin-top: 3px; width: 16px; height: 16px; border-radius: 50%;
+    background: var(--bg-primary); border: 1.5px solid var(--border-color);
+    box-shadow: 0 0 0 3px var(--bg-primary);
+    display: grid; place-items: center;
+    transition: background .3s ease, border-color .3s ease, box-shadow .3s ease;
+}
+.timeline-node.tl-completed .timeline-node-marker { background: var(--accent-color); border-color: var(--accent-color); }
+/* tick is grid-centered in the dot; tiny upward shift optically centers it (its vertex hangs low) */
+.timeline-node.tl-completed .timeline-node-marker::after {
+    content: ''; width: 5px; height: 2.5px; position: relative; top: -0.5px;
+    border-left: 1.5px solid var(--on-accent); border-bottom: 1.5px solid var(--on-accent); transform: rotate(-45deg);
+}
+.timeline-node.is-current .timeline-node-marker {
+    background: var(--bg-primary); border: 2px solid var(--accent-color);
+    box-shadow: 0 0 0 3px var(--bg-primary), 0 0 0 4px var(--timeline-ring);
+    animation: timeline-pulse 2.4s ease-in-out infinite;
+}
+.timeline-node.tl-rejected .timeline-node-marker { background: var(--error-color); border-color: var(--error-color); }
+.timeline-node.tl-supplement_required .timeline-node-marker { background: var(--bg-primary); border: 2px dashed var(--text-secondary); }
+.timeline-node-body { min-width: 0; padding-top: 1px; }
+.timeline-node-row { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; }
+.timeline-node-title { font-size: 14px; font-weight: 600; color: var(--text-primary); }
+.timeline-node.tl-pending .timeline-node-title { color: var(--text-muted); font-weight: 500; }
+.timeline-node-state { font-size: 11.5px; color: var(--text-muted); white-space: nowrap; }
+.timeline-node.is-current .timeline-node-state { color: var(--text-secondary); }
+.timeline-node.tl-rejected .timeline-node-state { color: var(--error-color); }
+.timeline-node-note { margin: 6px 0 0; font-size: 13px; line-height: 1.55; color: var(--text-secondary); }
+.timeline-node-reminder { margin: 5px 0 0; font-size: 12px; color: var(--text-muted); }
+
+/* ---- chat overview card (matches .doc-prep-card chrome) ---- */
+.timeline-card { margin-top: 10px; max-width: 440px; }
+.timeline-card-inner {
+    border: 1px solid var(--border-color); border-radius: var(--radius-md);
+    background: var(--bg-primary); box-shadow: var(--shadow-sm); padding: 15px 16px;
+}
+.timeline-card-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
+.timeline-card-eyebrow { font-size: 11px; font-weight: 600; letter-spacing: .05em; text-transform: uppercase; color: var(--text-muted); }
+.timeline-card-product { margin-top: 7px; font-size: 16px; font-weight: 600; line-height: 1.3; color: var(--text-primary); }
+.timeline-card-sub { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin: 4px 0 11px; font-size: 13px; color: var(--text-secondary); }
+.timeline-card-step { font-variant-numeric: tabular-nums; color: var(--text-muted); }
+.timeline-card .timeline-progress { margin-bottom: 13px; }
+.timeline-card-btn {
+    appearance: none; cursor: pointer; width: 100%; font-size: 13px; font-weight: 500;
+    color: var(--text-primary); background: var(--bg-secondary);
+    border: 1px solid var(--border-color); border-radius: var(--radius-sm);
+    padding: 8px 12px; transition: background .15s ease, border-color .15s ease;
+}
+.timeline-card-btn:hover { background: var(--bg-hover); border-color: var(--text-muted); }
+
+/* ---- submit-blocking notice (ChatRaw-styled, restrained) ---- */
+.timeline-blocking {
+    margin: 0 14px 10px; padding: 10px 12px; font-size: 13px; color: var(--text-secondary);
+    background: var(--bg-secondary); border: 1px solid var(--border-color);
+    border-left: 2px solid var(--error-color); border-radius: var(--radius-sm);
+}
+.timeline-blocking-title { margin: 0 0 6px; font-weight: 600; color: var(--text-primary); }
+.timeline-blocking ul { margin: 0; padding-left: 16px; }
+.timeline-blocking li { margin: 3px 0; display: flex; align-items: baseline; gap: 8px; justify-content: space-between; }
+.timeline-blocking li > span { flex: 1; min-width: 0; }
+/* per-item "Locate" → jumps to + red-highlights the field in the PDF viewer */
+.timeline-blocking-locate {
+    flex: none; appearance: none; cursor: pointer; white-space: nowrap;
+    font: inherit; font-size: 12px; font-weight: 500;
+    color: var(--error-color); background: transparent;
+    border: 1px solid var(--error-color); border-radius: var(--radius-sm);
+    padding: 1px 9px; transition: background .15s ease;
+}
+.timeline-blocking-locate:hover { background: rgba(220, 38, 38, 0.08); }
+
+/* published_documents has no PDF field — flash the overlay checklist card when located */
+.doc-overlay-card.doc-overlay-flag {
+    animation: doc-overlay-flash 1.2s ease-out 2;
+    border-color: var(--error-color);
+}
+@keyframes doc-overlay-flash {
+    0% { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.4); }
+    100% { box-shadow: 0 0 0 7px rgba(220, 38, 38, 0); }
+}
+@media (prefers-reduced-motion: reduce) {
+    .doc-overlay-card.doc-overlay-flag { animation: none; }
+}
+
+/* ---- motion (calm) ---- */
+@keyframes timeline-pulse {
+    0%, 100% { box-shadow: 0 0 0 3px var(--bg-primary), 0 0 0 4px var(--timeline-ring); }
+    50%      { box-shadow: 0 0 0 3px var(--bg-primary), 0 0 0 6px transparent; }
+}
+@media (prefers-reduced-motion: reduce) {
+    .timeline-node-marker, .timeline-progress-fill { transition: none !important; }
+    .timeline-node.is-current .timeline-node-marker { animation: none !important; }
+}
