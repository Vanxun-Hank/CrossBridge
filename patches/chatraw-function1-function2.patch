+        clampLayoutWidth(target, width) {
+            const viewportWidth = document.documentElement.clientWidth || window.innerWidth;
+            const minimumChatWidth = 280;
+            if (target === 'sidebar') {
+                const documentPanelWidth = this.documentPreparation.panelOpen
+                    ? document.querySelector('.doc-prep-panel')?.getBoundingClientRect().width
+                        || this.layoutSizing.documentPanelWidth
+                    : 0;
+                const maximum = Math.min(420, viewportWidth - documentPanelWidth - minimumChatWidth);
+                return Math.max(220, Math.min(maximum, width));
+            }
+            const sidebarWidth = document.querySelector('.sidebar')?.getBoundingClientRect().width
+                || (this.sidebarCollapsed ? 72 : this.layoutSizing.sidebarWidth);
+            const maximum = Math.min(760, viewportWidth - sidebarWidth - minimumChatWidth);
+            return Math.max(320, Math.min(maximum, width));
+        },
+
+        setLayoutWidth(target, width, persist = true) {
+            const nextWidth = Math.round(this.clampLayoutWidth(target, width));
+            if (target === 'sidebar') {
+                this.layoutSizing.sidebarWidth = nextWidth;
+                if (persist) localStorage.setItem('chatraw_sidebar_width', String(nextWidth));
+            } else {
+                this.layoutSizing.documentPanelWidth = nextWidth;
+                if (persist) localStorage.setItem('crossbridge_doc_panel_width', String(nextWidth));
+            }
+        },
+
+        startLayoutResize(target, event) {
+            if (!this.canResizeLayout()) return;
+            event.preventDefault();
+            this.layoutSizing.activeTarget = target;
+            this.layoutSizing.startX = event.clientX;
+            this.layoutSizing.startWidth = event.currentTarget.parentElement?.getBoundingClientRect().width
+                || (target === 'sidebar'
+                    ? this.layoutSizing.sidebarWidth
+                    : this.layoutSizing.documentPanelWidth);
+            try {
+                event.currentTarget.setPointerCapture?.(event.pointerId);
+            } catch (e) {
+                // Pointer capture is optional; window listeners still keep the drag active.
+            }
+        },
+
+        continueLayoutResize(event) {
