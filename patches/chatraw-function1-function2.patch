+        // Send message
+        async sendMessage() {
+            let message = this.inputMessage.trim();
+            if (!message || this.isGenerating) return;
+
+            // Function 1: when loan-matching mode is active, the input box drives the
+            // clarification slot-filling (Claude-Code style) instead of normal RAG chat.
+            if (this.loanMatching.active && this.loanMatching.session) {
+                this.inputMessage = '';
+                this.$nextTick(() => this.autoResize(this.$refs.inputBox));
+                await this.handleLoanChatTurn(message);
+                return;
+            }
+
+            this.inputMessage = '';
+            this.$nextTick(() => this.autoResize(this.$refs.inputBox));
+            this.isGenerating = true;
+            this.abortController = new AbortController();
+            
+            // Call transform_input hooks to allow plugins to modify the input
+            const transformResult = await this.callHook('transform_input', message);
+            if (transformResult?.success && transformResult.content) {
+                message = transformResult.content;
+            }
