+            if (!target) return;
+            const delta = event.clientX - this.layoutSizing.startX;
+            const width = target === 'sidebar'
+                ? this.layoutSizing.startWidth + delta
+                : this.layoutSizing.startWidth - delta;
+            this.setLayoutWidth(target, width, false);
+        },
+
+        finishLayoutResize() {
+            const target = this.layoutSizing.activeTarget;
+            if (!target) return;
+            this.setLayoutWidth(
+                target,
+                target === 'sidebar'
+                    ? this.layoutSizing.sidebarWidth
+                    : this.layoutSizing.documentPanelWidth
+            );
+            this.layoutSizing.activeTarget = '';
+        },
+
+        adjustLayoutWidth(target, delta) {
+            const width = target === 'sidebar'
+                ? this.layoutSizing.sidebarWidth
+                : this.layoutSizing.documentPanelWidth;
+            this.setLayoutWidth(target, width + delta);
+        },
+
+        resetLayoutWidth(target) {
