+            this.messages.push({
+                role: 'user',
+                content: message
+            });
+            this.$nextTick(() => this.scrollToBottom());
+            // Router is read-only: it may offer a CTA, but it never opens a workspace or stores SME data.
+            const matchingIntentPromise = this.fetchLoanMatchingIntent(message);
