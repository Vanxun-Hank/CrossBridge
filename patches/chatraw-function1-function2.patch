+    margin-top: 17px;
+}
+
+.loan-clarify-input .loan-btn {
+    align-self: flex-start;
+}
+
+.loan-match-actions small,
+.loan-profile-actions small {
+    color: var(--text-secondary);
+}
+
+.loan-results {
+    margin-top: 16px;
+}
+
+.loan-product-grid {
+    display: grid;
+    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
+    gap: 12px;
+    margin-top: 16px;
+}
+
+.loan-product-card {
+    padding: 14px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-sm);
+    background: var(--bg-secondary);
+}
+
+.loan-product-card h3 {
+    margin: 10px 0;
+    font-size: 17px;
+}
+
+.loan-product-description {
+    margin-bottom: 10px;
+    color: var(--text-secondary);
+    font-size: 13px;
+}
+
+.loan-product-card dl div {
+    display: grid;
+    grid-template-columns: 72px minmax(0, 1fr);
+    gap: 7px;
+    margin-bottom: 6px;
+    font-size: 13px;
+}
+
+.loan-product-card dt {
+    color: var(--text-secondary);
+}
+
+.loan-product-card ul {
+    margin: 7px 0 0 18px;
+    font-size: 13px;
+}
+
+.loan-rm-note {
+    margin-top: 10px;
+    font-size: 12px;
+}
+
+.loan-source-meta {
+    display: flex;
+    flex-direction: column;
+    gap: 4px;
+    margin-top: 12px;
+    padding-top: 10px;
+    border-top: 1px solid var(--border-color);
+    color: var(--text-secondary);
+    font-size: 12px;
+}
+
+.loan-source-meta a {
+    color: var(--accent-color);
+    font-weight: 600;
+}
+
+@media (max-width: 960px) {
+    .loan-workspace-grid {
+        grid-template-columns: 1fr;
+    }
+
+    .loan-workspace-header {
+        align-items: flex-start;
+        flex-direction: column;
+    }
+}
+
+@media (max-width: 640px) {
+    .loan-workspace {
+        padding: 14px;
+    }
+
+    .loan-form-grid {
+        grid-template-columns: 1fr;
+    }
+}
+
+/* ============================================================
+   Function 1 — chat-embedded loan matching (inline cards)
+   Minimal, mono, restrained — harmonises with ChatRaw.
+   ============================================================ */
+
+/* Mode banner */
+.loan-mode-banner {
+    position: sticky;
+    top: 0;
+    z-index: 5;
+    display: flex;
+    align-items: center;
+    gap: 8px;
+    align-self: center;
+    margin: 8px auto 0;
+    padding: 5px 6px 5px 12px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-full);
+    background: var(--bg-primary);
+    color: var(--text-secondary);
+    font-size: 12px;
+    line-height: 1.4;
+    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
+}
+.loan-mode-dot {
+    width: 7px;
+    height: 7px;
+    border-radius: var(--radius-full);
+    background: var(--accent-color);
+    animation: loan-pulse 1.6s ease-in-out infinite;
+}
+@keyframes loan-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }
+.loan-mode-text { font-weight: 500; color: var(--text-primary); }
+.loan-mode-exit {
+    margin-left: 2px;
+    padding: 3px 12px;
+    border: none;
+    border-radius: var(--radius-full);
+    background: var(--bg-tertiary);
+    color: var(--text-primary);
+    font-size: 12px;
+    cursor: pointer;
+}
+.loan-mode-exit:hover { background: var(--bg-hover); }
+
+/* Clarify card (the AI question + chips) */
+.loan-clarify {
+    margin-top: 6px;
+    padding: 14px 16px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-md);
+    background: var(--bg-secondary);
+}
+.loan-clarify-top { margin-bottom: 8px; }
+.loan-progress-pill {
+    display: inline-flex;
+    padding: 2px 10px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-full);
+    background: var(--bg-primary);
+    color: var(--text-secondary);
+    font-size: 11px;
+    letter-spacing: 0.02em;
+}
+.loan-clarify-q {
+    color: var(--text-primary);
+    font-size: var(--text-base);
+    font-weight: 500;
+    line-height: 1.5;
+}
+.loan-chip-row {
+    display: flex;
+    flex-wrap: wrap;
+    gap: 8px;
+    margin-top: 12px;
+}
+.loan-chip {
+    padding: 7px 16px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-full);
+    background: var(--bg-primary);
+    color: var(--text-primary);
+    font-size: var(--text-sm);
+    cursor: pointer;
+    transition: background 140ms ease, color 140ms ease, border-color 140ms ease;
+}
+.loan-chip:hover:not(:disabled) {
+    background: var(--accent-color);
+    border-color: var(--accent-color);
+    color: var(--on-accent);
+}
+.loan-chip:disabled { opacity: 0.45; cursor: default; }
+.loan-clarify-hint {
+    margin-top: 10px;
+    color: var(--text-muted);
+    font-size: var(--text-xs);
+    line-height: 1.5;
+}
+.loan-clarify-warn {
+    margin-top: 8px;
+    padding: 8px 10px;
+    border-radius: var(--radius-sm);
+    background: var(--bg-tertiary);
+    color: var(--text-secondary);
+}
+
+/* Inline draft card + inline results container */
+.loan-draft-inline,
+.loan-results-inline {
+    margin-top: 6px;
+    padding: 16px 18px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-md);
+    background: var(--bg-secondary);
+}
+.loan-draft-note {
+    display: block;
+    margin-top: 10px;
+    color: var(--text-muted);
+    font-size: var(--text-xs);
+}
+
+/* Two-per-row product grid inside the chat column */
+.loan-product-grid.loan-inline-grid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+}
+@media (max-width: 720px) {
+    .loan-product-grid.loan-inline-grid {
+        grid-template-columns: 1fr;
+    }
+}
+
+/* F1 anchored clarification panel (sits above the composer, updates in place) */
+.loan-ask {
+    margin: 0 auto 10px;
+    padding: 14px 16px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-md);
+    background: var(--bg-secondary);
+    animation: loan-ask-in 200ms ease;
+}
+@keyframes loan-ask-in {
+    from { opacity: 0; transform: translateY(4px); }
+    to   { opacity: 1; transform: translateY(0); }
+}
+.loan-ask-top {
+    display: flex;
+    align-items: center;
+    gap: 10px;
+    margin-bottom: 8px;
+}
+.loan-ask-dots { display: inline-flex; gap: 5px; }
+.loan-ask-dot {
+    width: 7px;
+    height: 7px;
+    border-radius: var(--radius-full);
+    background: var(--bg-tertiary);
+    box-shadow: inset 0 0 0 1px var(--border-color);
+    transition: background 160ms ease;
+}
+.loan-ask-dot.done {
+    background: var(--accent-color);
+    box-shadow: none;
+}
+.loan-ask-count {
+    color: var(--text-secondary);
+    font-size: 11px;
+    letter-spacing: 0.02em;
+}
+.loan-ask-q {
+    color: var(--text-primary);
+    font-size: var(--text-base);
+    font-weight: 500;
+    line-height: 1.5;
+}
+.loan-ask-chips {
+    display: flex;
+    flex-wrap: wrap;
+    gap: 8px;
+    margin-top: 12px;
+}
+.loan-ask-hint {
+    margin-top: 10px;
+    color: var(--text-muted);
+    font-size: var(--text-xs);
+    line-height: 1.5;
+}
+.loan-ask-warn {
+    padding: 8px 10px;
+    border-radius: var(--radius-sm);
+    background: var(--bg-tertiary);
+    color: var(--text-secondary);
+}
+
+/* Two AI modes segmented switch (composer) */
+.ai-mode-switch {
+    display: inline-flex;
+    gap: 2px;
+    margin: 0 auto 10px;
+    padding: 3px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-full);
+    background: var(--bg-tertiary);
+}
+.ai-mode-btn {
+    display: inline-flex;
+    align-items: center;
+    gap: 6px;
+    padding: 6px 16px;
+    border: none;
+    border-radius: var(--radius-full);
+    background: transparent;
+    color: var(--text-secondary);
+    font-size: var(--text-sm);
+    font-weight: 500;
+    cursor: pointer;
+    transition: background 140ms ease, color 140ms ease;
+}
+.ai-mode-btn i { font-size: 15px; }
+.ai-mode-btn:hover:not(.active) { color: var(--text-primary); }
+.ai-mode-btn.active {
+    background: var(--accent-color);
+    color: var(--on-accent);
+}
+
+/* Compact bottom composer: preserve the transcript and F1 product-card viewport. */
+.input-area {
+    padding: 4px 24px 8px;
+}
+
+.input-toolbar {
+    bottom: 6px;
+    left: 9px;
+}
+
+.input-wrapper {
+    padding: 8px 10px 34px;
+}
+
+.input-wrapper textarea {
+    min-height: 20px;
+    max-height: 180px;
+    line-height: 1.4;
+}
+
+.btn-send,
+.btn-stop {
+    right: 6px;
+    bottom: 6px;
+    width: 28px;
+    height: 28px;
+    font-size: 15px;
+}
+
+.loan-ask {
+    margin-bottom: 4px;
+    padding: 9px 11px;
+}
+
+.loan-ask-top {
+    margin-bottom: 4px;
+}
+
+.loan-ask-q {
+    line-height: 1.35;
+}
+
+.loan-ask-chips {
+    gap: 6px;
+    margin-top: 7px;
+}
+
+.ai-mode-switch {
+    margin: 0 auto 4px;
+    padding: 2px;
+}
+
+.ai-mode-btn {
+    gap: 4px;
+    padding: 3px 10px;
+    font-size: var(--text-xs);
+}
+
+.ai-mode-btn i {
+    font-size: 12px;
+}
+
+@media (max-width: 768px) {
+    .input-area {
+        padding: 4px 12px max(12px, env(safe-area-inset-bottom) + 6px);
+    }
+}
+
+/* ============================================================
+   Function 2 — document preparation right-side workbench
+   ============================================================ */
+
+body {
+    --chatraw-doc-panel-layout-width: clamp(
+        320px,
+        var(--chatraw-doc-panel-width, 460px),
+        calc(100vw - var(--chatraw-active-sidebar-width, 280px) - 280px)
+    );
+}
+
+.main-content {
+    transition: margin-right 180ms ease;
+}
+
+.main-content.doc-panel-open {
+    margin-right: var(--chatraw-doc-panel-layout-width);
+}
+
+.crossbridge-doc-prep-collapsed {
+    margin-top: 0;
+}
+
+.loan-doc-prep-btn {
+    display: inline-flex;
+    align-items: center;
+    gap: 6px;
+    margin-top: 14px;
+}
+
+.doc-overview-bubble {
+    display: flex;
+    flex-direction: column;
+    align-items: flex-start;
+    gap: 7px;
+    max-width: 560px;
+    margin-top: 8px;
+    padding: 14px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-md);
+    background: var(--bg-secondary);
+}
+
+.doc-overview-bubble small,
+.doc-prep-muted {
+    color: var(--text-secondary);
+    font-size: 12px;
+    line-height: 1.5;
+}
+
+.doc-prep-panel {
+    position: fixed;
+    top: 0;
+    right: 0;
+    z-index: 24;
+    display: flex;
+    width: var(--chatraw-doc-panel-layout-width);
+    height: 100dvh;
+    flex-direction: column;
+    border-left: 1px solid var(--border-color);
+    background: var(--bg-secondary);
+    box-shadow: -12px 0 32px rgba(0, 0, 0, 0.08);
+    transition: width 180ms ease;
+}
+
+.layout-resizer {
+    position: absolute;
+    top: 0;
+    z-index: 30;
+    width: 9px;
+    height: 100%;
+    cursor: col-resize;
+    touch-action: none;
+}
+
+.layout-resizer::before {
+    position: absolute;
+    top: 0;
+    bottom: 0;
+    left: 4px;
+    width: 1px;
+    background: transparent;
+    content: '';
+    transition: background-color 120ms ease, box-shadow 120ms ease;
+}
+
+.layout-resizer:hover::before,
+.layout-resizer:focus-visible::before,
+.layout-resizing .layout-resizer::before {
+    background: var(--text-secondary);
+    box-shadow: 0 0 0 1px var(--bg-primary);
+}
+
+.sidebar-layout-resizer {
+    right: -5px;
+}
+
+.doc-panel-layout-resizer {
+    left: -5px;
+}
+
+body.layout-resizing {
+    cursor: col-resize;
+    user-select: none;
+}
+
+body.layout-resizing .sidebar,
+body.layout-resizing .main-content,
+body.layout-resizing .doc-prep-panel {
+    transition: none;
+}
+
+.doc-prep-header {
+    display: flex;
+    align-items: flex-start;
+    justify-content: space-between;
+    gap: 12px;
+    padding: 18px 18px 14px;
+    border-bottom: 1px solid var(--border-color);
+}
+
+.doc-prep-header h2 {
+    font-size: 17px;
+}
+
+.doc-prep-header p {
+    margin-top: 5px;
+    color: var(--text-secondary);
+    font-size: 11px;
+    line-height: 1.5;
+}
+
+.doc-prep-scroll {
+    flex: 1;
+    overflow-y: auto;
+    padding: 14px;
+}
+
+.doc-prep-loading,
+.doc-prep-error {
+    margin-bottom: 10px;
+    padding: 9px 11px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-sm);
+    background: var(--bg-primary);
+    color: var(--text-secondary);
+    font-size: 12px;
+}
+
+.doc-prep-error {
+    color: #b42318;
+}
+
+.doc-prep-card {
+    margin-bottom: 12px;
+    padding: 13px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-md);
+    background: var(--bg-primary);
+}
+
+.doc-prep-card h3,
+.doc-template-section > h3 {
+    margin-bottom: 9px;
+    color: var(--text-primary);
+    font-size: 13px;
+}
+
+.doc-scenario-grid {
+    display: grid;
+    grid-template-columns: 1fr 1fr;
+    gap: 8px;
+    margin-bottom: 9px;
+}
+
+.doc-scenario-grid button {
+    display: flex;
+    flex-direction: column;
+    gap: 2px;
+    padding: 10px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-sm);
+    background: var(--bg-secondary);
+    color: var(--text-primary);
+    cursor: pointer;
+    text-align: left;
+}
+
+.doc-scenario-grid button.recommended {
+    border-style: dashed;
+}
+
+.doc-scenario-grid button.active {
+    border-color: var(--text-primary);
+    background: var(--bg-tertiary);
+}
+
+.doc-scenario-grid small {
+    color: var(--text-secondary);
+    font-size: 10px;
+}
+
+.doc-prep-field {
+    display: flex;
+    flex-direction: column;
+    gap: 4px;
+    margin-top: 9px;
+    color: var(--text-secondary);
+    font-size: 12px;
+}
+
+.doc-prep-field input,
+.doc-prep-field select,
+.doc-prep-field textarea {
+    width: 100%;
+    padding: 8px 9px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-sm);
+    background: var(--bg-secondary);
+    color: var(--text-primary);
+    font: inherit;
+}
+
+.doc-prep-field textarea {
+    resize: vertical;
+}
+
+.doc-overlay-card strong {
+    display: block;
+    font-size: 13px;
+}
+
+.doc-overlay-card p {
+    margin-top: 6px;
+    color: var(--text-secondary);
+    font-size: 12px;
+    line-height: 1.55;
+}
+
+.doc-overlay-card a {
+    display: inline-block;
+    margin-top: 8px;
+    color: var(--accent-color);
+    font-size: 12px;
+    font-weight: 600;
+}
+
+.doc-check-item {
+    display: grid;
+    grid-template-columns: 16px 1fr;
+    column-gap: 7px;
+    align-items: start;
+    padding: 5px 0;
+    color: var(--text-primary);
+    font-size: 12px;
+}
+
+.doc-check-item input {
+    margin-top: 3px;
+}
+
+.doc-check-item small {
+    grid-column: 2;
+    color: var(--text-muted);
+    font-size: 10px;
+}
+
+.doc-tier-public_source_hint {
+    border-left: 3px solid #3b82f6;
+}
+
+.doc-tier-suggested_preparation {
+    border-left: 3px solid #f59e0b;
+}
+
+.doc-tier-bank_to_confirm,
+.doc-tier-product {
+    border-left: 3px solid #8b5cf6;
+}
+
+.doc-validation {
+    border-color: #f79009;
+    background: #fffaeb;
+    color: #93370d;
+}
+
+[data-theme="dark"] .doc-validation {
+    background: #241a04;
+    color: #fedf89;
+}
+
+.doc-validation li {
+    margin-left: 18px;
+    font-size: 12px;
+}
+
+.doc-official-section {
+    margin-top: 16px;
+}
+
+.doc-form-list {
+    display: flex;
+    flex-direction: column;
+    gap: 8px;
+    margin: 10px 0;
+}
+
+.doc-form-chip {
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    gap: 10px;
+    width: 100%;
+    padding: 10px 12px;
+    text-align: left;
+    color: var(--text-primary);
+    background: var(--bg-primary);
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-sm);
+    cursor: pointer;
+}
+
+.doc-form-chip:hover {
+    background: var(--bg-hover);
+}
+
+.doc-form-chip.active {
+    border-color: var(--accent-color);
+    box-shadow: inset 0 0 0 1px var(--accent-color);
+}
+
+.doc-form-chip-name {
+    font-weight: 600;
+    font-size: 13px;
+}
+
+.doc-form-badges {
+    display: flex;
+    flex-wrap: wrap;
+    gap: 4px;
+    justify-content: flex-end;
+}
+
+.doc-badge {
+    font-size: 10px;
+    line-height: 1.7;
+    padding: 0 6px;
+    border-radius: 999px;
+    border: 1px solid var(--border-color);
+    color: var(--text-muted);
+    white-space: nowrap;
+}
+
+.doc-badge-match {
+    color: var(--on-accent);
+    background: var(--accent-color);
+    border-color: var(--accent-color);
+}
+
+.doc-badge-missing {
+    color: #92400e;
+    background: #fef3c7;
+    border-color: #fcd34d;
+}
+
+.doc-badge-draft {
+    color: #1d4ed8;
+    background: #dbeafe;
+    border-color: #bfdbfe;
+}
+
+.doc-form-cache-missing {
+    margin: 8px 0;
+    padding: 12px;
+    border: 1px solid #fcd34d;
+    border-radius: var(--radius-sm);
+    background: #fffbeb;
+    font-size: 12px;
+}
+
+.doc-form-cache-missing a {
+    display: inline-block;
+    margin-top: 6px;
+    font-weight: 600;
+}
+
+.doc-viewer-wrap {
+    margin-top: 10px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-sm);
+    overflow: hidden;
+    background: #f3f4f6;
+}
+
+.doc-viewer-frame {
+    display: block;
+    width: 100%;
+    height: 70vh;
+    min-height: 420px;
+    border: 0;
+}
+
+.doc-terms-overlay {
+    position: absolute;
+    inset: 0;
+    z-index: 20;
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    padding: 20px;
+    background: rgba(0, 0, 0, 0.4);
+}
+
+.doc-terms-card {
+    width: 100%;
+    max-width: 420px;
+    padding: 18px;
+    border-radius: var(--radius-md);
+    background: var(--bg-primary);
+    border: 1px solid var(--border-color);
+    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
+}
+
+.doc-terms-card h4 {
+    margin: 0 0 8px;
+}
+
+.doc-terms-card p {
+    margin: 0 0 8px;
+    font-size: 13px;
+    color: var(--text-muted);
+}
+
+.doc-terms-actions {
+    display: flex;
+    justify-content: flex-end;
+    gap: 8px;
+    margin-top: 14px;
+}
+
+.doc-prep-actions {
+    display: flex;
+    justify-content: flex-end;
+    gap: 8px;
+    padding: 12px 14px;
+    border-top: 1px solid var(--border-color);
+    background: var(--bg-primary);
+}
+
+@media (max-width: 900px) {
+    .main-content.doc-panel-open {
+        margin-right: 0;
+    }
+
+    .doc-prep-panel {
+        width: 100%;
+    }
+
+    .layout-resizer {
+        display: none !important;
+    }
+}
+
+/* The old "print the workbench HTML" path is retired: official forms are printed by
+   the embedded PDF.js viewer (saveDocument() -> hidden iframe -> print), so the genuine
+   bank PDF is what reaches the printer — not a CSS rendering of the panel. */
