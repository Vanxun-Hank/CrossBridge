+    pointer-events: none;
+}
+
+.plugin-more-item i {
+    font-size: 16px;
+    width: 20px;
+    text-align: center;
+    flex-shrink: 0;
+}
+
+.plugin-more-item span {
+    white-space: nowrap;
+    overflow: hidden;
+    text-overflow: ellipsis;
+}
+
+/* Plugin Fullscreen Modal */
+.plugin-fullscreen-modal {
+    z-index: 1000;
+}
+
+.plugin-fullscreen-content {
+    width: 100%;
+    max-width: 900px;
+    max-height: 90vh;
+    background: var(--bg-primary);
+    border-radius: var(--radius-lg);
+    overflow: hidden;
+    box-shadow: var(--shadow-lg);
+    border: 1px solid var(--border-color);
+}
+
+/* Mobile: Plugin Toolbar */
+@media (max-width: 768px), (max-height: 500px) and (max-width: 900px) and (pointer: coarse) {
+    .plugin-toolbar-area {
+        gap: 2px;
+    }
+
+    .plugin-toolbar-divider {
+        margin: 0 2px;
+    }
+
+    .plugin-fullscreen-content {
+        max-width: 100%;
+        max-height: 100%;
+        border-radius: 0;
+        border: none;
+    }
+
+    .plugin-more-menu {
+        right: auto;
+        left: 50%;
+        transform: translateX(-50%);
+        min-width: 200px;
+    }
+
+    .plugin-settings-modal {
+        width: calc(100vw - 24px);
+        max-width: calc(100vw - 24px);
+        max-height: calc(100dvh - 24px);
+    }
+
+    .plugin-settings-content {
+        min-height: 0;
+        -webkit-overflow-scrolling: touch;
+    }
+}
+
+/* Tablet: Plugin Toolbar */
+@media (min-width: 769px) and (max-width: 1024px) {
+    .btn-tool.plugin-btn {
+        min-width: 44px;
+        min-height: 44px;
+    }
+}
+
+/* --- Touch screen: disable sticky hover effects --- */
+@media (hover: none) {
+    .feature:hover {
+        transform: none;
+        border-color: var(--border-color);
+        box-shadow: none;
+    }
+
+    .btn-new-chat:hover {
+        transform: none;
+        box-shadow: var(--shadow-sm);
+    }
+
+    .btn-primary:hover {
+        opacity: 1;
+        transform: none;
+    }
+
+    .btn-send:hover:not(:disabled) {
+        transform: none;
+    }
+
+    .btn-stop:hover {
+        transform: none;
+    }
+
+    .chat-item:hover .btn-delete {
+        opacity: 1;
+    }
+
+    .model-card:hover {
+        border-color: var(--border-color);
+    }
+}
+
+/* CrossBridge Function 1: SME loan matching */
+.crossbridge-business-nav {
+    padding: 12px 12px 8px;
+    border-bottom: 1px solid var(--border-color);
+}
+
+.crossbridge-business-label {
+    padding: 0 8px 6px;
+    color: var(--text-muted);
+    font-size: 11px;
+    font-weight: 700;
+    letter-spacing: 0.08em;
+}
+
+.crossbridge-business-link {
+    display: flex;
+    align-items: center;
+    width: 100%;
+    gap: 9px;
+    padding: 9px 10px;
+    color: var(--text-primary);
+    background: transparent;
+    border: 1px solid transparent;
+    border-radius: var(--radius-sm);
+    cursor: pointer;
+    text-align: left;
+}
+
+.crossbridge-business-link:hover,
+.crossbridge-business-link.active {
+    background: var(--bg-primary);
+    border-color: var(--border-color);
+}
+
+.crossbridge-business-collapsed {
+    align-self: center;
+    margin: 10px 0 4px;
+}
+
+.loan-matching-cta {
+    max-width: 560px;
+    margin-top: 14px;
+    padding: 14px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-md);
+    background: var(--bg-secondary);
+}
+
+.loan-matching-cta-title {
+    margin-bottom: 4px;
+    font-weight: 700;
+}
+
+.loan-matching-cta-text {
+    margin-bottom: 12px;
+    color: var(--text-secondary);
+    font-size: 13px;
+}
+
+.loan-workspace {
+    flex: 1;
+    overflow-y: auto;
+    padding: 26px;
+    background: var(--bg-secondary);
+}
+
+.loan-workspace-header,
+.loan-panel-header,
+.loan-form-actions,
+.loan-profile-actions,
+.loan-match-actions {
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    gap: 14px;
+}
+
+.loan-workspace-header {
+    max-width: 1240px;
+    margin: 0 auto 18px;
+}
+
+.loan-back-link {
+    display: inline-flex;
+    align-items: center;
+    gap: 2px;
+    margin-bottom: 8px;
+    color: var(--text-secondary);
+    background: transparent;
+    border: 0;
+    cursor: pointer;
+}
+
+.loan-workspace h1 {
+    margin-bottom: 5px;
+    font-size: 28px;
+}
+
+.loan-workspace p {
+    color: var(--text-secondary);
+}
+
+.loan-demo-identity {
+    display: flex;
+    flex-direction: column;
+    max-width: 390px;
+    padding: 11px 13px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-sm);
+    background: var(--bg-primary);
+    font-size: 12px;
+}
+
+.loan-demo-identity span {
+    color: var(--text-secondary);
+}
+
+.loan-workspace-grid,
+.loan-results {
+    max-width: 1240px;
+    margin: 0 auto;
+}
+
+.loan-workspace-grid {
+    display: grid;
+    grid-template-columns: minmax(0, 1.25fr) minmax(320px, 0.75fr);
+    gap: 16px;
+}
+
+.loan-panel {
+    padding: 18px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-md);
+    background: var(--bg-primary);
+    box-shadow: var(--shadow-sm);
+}
+
+.loan-panel h2 {
+    margin-bottom: 3px;
+    font-size: 18px;
+}
+
+.loan-panel-header p {
+    font-size: 13px;
+}
+
+.loan-status-tag,
+.loan-demo-tag {
+    display: inline-flex;
+    flex-shrink: 0;
+    padding: 3px 8px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-full);
+    color: var(--text-secondary);
+    font-size: 11px;
+    line-height: 1.4;
+}
+
+.loan-progress {
+    margin: 18px 0;
+}
+
+.loan-progress-label {
+    display: flex;
+    justify-content: space-between;
+    margin-bottom: 7px;
+    font-size: 13px;
+}
+
+.loan-progress-track {
+    display: block;
+    height: 5px;
+    overflow: hidden;
+    border-radius: var(--radius-full);
+    background: var(--bg-tertiary);
+}
+
+.loan-progress-track span {
+    display: block;
+    height: 100%;
+    background: var(--text-primary);
+    transition: width 180ms ease;
+}
+
+.loan-form-grid {
+    display: grid;
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+    gap: 13px;
+}
+
+.loan-form-grid label,
+.loan-clarify-input {
+    display: flex;
+    flex-direction: column;
+    gap: 5px;
+}
+
+.loan-form-grid label span {
+    color: var(--text-secondary);
+    font-size: 12px;
+    font-weight: 600;
+}
+
+.loan-form-grid input,
+.loan-form-grid select,
+.loan-clarify-input textarea {
+    width: 100%;
+    padding: 9px 10px;
+    color: var(--text-primary);
+    background: var(--bg-primary);
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-sm);
+    font: inherit;
+}
+
+.loan-form-grid input:focus,
+.loan-form-grid select:focus,
+.loan-clarify-input textarea:focus {
+    border-color: var(--border-focus);
+    outline: none;
+}
+
+.loan-form-actions,
+.loan-profile-actions,
+.loan-match-actions {
+    justify-content: flex-start;
+    flex-wrap: wrap;
+    margin-top: 17px;
+}
+
+.loan-btn {
+    padding: 8px 12px;
+    color: var(--text-primary);
+    background: var(--bg-primary);
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-sm);
+    cursor: pointer;
+    font-weight: 600;
+}
+
+.loan-btn:hover:not(:disabled) {
+    background: var(--bg-hover);
+}
+
+.loan-btn-primary {
+    color: var(--on-accent);
+    background: var(--accent-color);
+    border-color: var(--accent-color);
+}
+
+.loan-btn-primary:hover:not(:disabled) {
+    opacity: 0.86;
+    background: var(--accent-color);
+}
+
+.loan-btn-danger {
+    color: var(--error-color);
+}
+
+.loan-btn:disabled {
+    cursor: not-allowed;
+    opacity: 0.45;
+}
+
+.loan-agent-question,
+.loan-workspace-notice,
+.loan-workspace-error,
+.loan-workspace-loading {
+    margin-top: 17px;
+    padding: 12px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-sm);
+    background: var(--bg-secondary);
+}
+
+.loan-agent-question span,
+.loan-missing-list strong {
+    display: block;
+    margin-bottom: 4px;
+    color: var(--text-secondary);
+    font-size: 11px;
+    font-weight: 700;
+    letter-spacing: 0.08em;
+}
+
+.loan-agent-question p {
+    color: var(--text-primary);
+    font-weight: 600;
+}
+
+.loan-agent-ready {
+    border-color: var(--success-color);
+}
+
+.loan-workspace-notice,
+.loan-workspace-error {
+    color: var(--error-color);
+    font-size: 13px;
+}
+
+.loan-workspace-loading,
+.loan-workspace-error {
+    max-width: 1240px;
+    margin: 0 auto 16px;
+}
+
+.loan-missing-list {
+    display: flex;
+    flex-wrap: wrap;
+    gap: 6px;
+    margin-top: 16px;
+}
+
+.loan-missing-list strong {
+    width: 100%;
+}
+
+.loan-missing-list span {
+    padding: 3px 7px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-full);
+    color: var(--text-secondary);
+    font-size: 12px;
+}
+
+.loan-clarify-input {
+    margin-top: 17px;
+}
+
+.loan-clarify-input .loan-btn {
+    align-self: flex-start;
+}
+
+.loan-match-actions small,
+.loan-profile-actions small {
+    color: var(--text-secondary);
+}
+
+.loan-results {
+    margin-top: 16px;
+}
+
+.loan-product-grid {
+    display: grid;
+    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
+    gap: 12px;
+    margin-top: 16px;
+}
+
+.loan-product-card {
+    padding: 14px;
+    border: 1px solid var(--border-color);
+    border-radius: var(--radius-sm);
+    background: var(--bg-secondary);
+}
+
+.loan-product-card h3 {
+    margin: 10px 0;
+    font-size: 17px;
+}
+
+.loan-product-description {
+    margin-bottom: 10px;
+    color: var(--text-secondary);
+    font-size: 13px;
+}
+
+.loan-product-card dl div {
+    display: grid;
+    grid-template-columns: 72px minmax(0, 1fr);
+    gap: 7px;
+    margin-bottom: 6px;
+    font-size: 13px;
+}
+
+.loan-product-card dt {
+    color: var(--text-secondary);
+}
+
+.loan-product-card ul {
+    margin: 7px 0 0 18px;
+    font-size: 13px;
+}
+
+.loan-rm-note {
+    margin-top: 10px;
+    font-size: 12px;
+}
+
+.loan-source-meta {
+    display: flex;
+    flex-direction: column;
+    gap: 4px;
+    margin-top: 12px;
+    padding-top: 10px;
+    border-top: 1px solid var(--border-color);
+    color: var(--text-secondary);
+    font-size: 12px;
+}
+
+.loan-source-meta a {
+    color: var(--accent-color);
+    font-weight: 600;
+}
+
+@media (max-width: 960px) {
+    .loan-workspace-grid {
+        grid-template-columns: 1fr;
+    }
+
+    .loan-workspace-header {
+        align-items: flex-start;
+        flex-direction: column;
+    }
+}
+
+@media (max-width: 640px) {
+    .loan-workspace {
+        padding: 14px;
+    }
+
+    .loan-form-grid {
+        grid-template-columns: 1fr;
+    }
+}
