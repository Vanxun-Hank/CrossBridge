+                this.documentPreparation.templateSaving[templateCode] = false;
+            }
+        },
+
+        runDocValidation() {
+            const pkg = this.documentPreparation.package;
+            if (!pkg) {
+                this.documentPreparation.validation = [];
+                return [];
+            }
+            const warnings = [];
+            const templates = pkg.templates || [];
+            const formCode = pkg.scenario_code === 'import_payment'
+                ? 'supplier_payment_form'
+                : 'export_fulfillment_form';
+            const form = templates.find(item => item.code === formCode);
+            const content = form?.content || {};
+            const value = code => String(content[code] || '').trim();
+            const normalized = raw => String(raw || '').replace(/[,\s]/g, '').toUpperCase();
+            if (value('swift_bic') && !/^[A-Z0-9]{8}([A-Z0-9]{3})?$/i.test(value('swift_bic'))) {
+                warnings.push({ code: 'swift_bic' });
+            }
+            if (value('supplier_name') && value('beneficiary_account_name')
+                && normalized(value('supplier_name')) !== normalized(value('beneficiary_account_name'))) {
+                warnings.push({ code: 'beneficiary_name' });
+            }
+            if ((value('invoice_amount') && value('payment_amount')
+                && normalized(value('invoice_amount')) !== normalized(value('payment_amount')))
+                || (value('invoice_currency') && value('payment_currency')
+                    && normalized(value('invoice_currency')) !== normalized(value('payment_currency')))) {
+                warnings.push({ code: 'invoice_payment' });
+            }
+            if (pkg.scenario_code === 'import_payment'
+                && (!value('charge_bearer') || value('charge_bearer') === 'PENDING_CONFIRMATION')) {
+                warnings.push({ code: 'charge_bearer' });
+            }
+            const missingFields = templates.flatMap(template => template.fields
+                .filter(field => field.core && !String(template.content?.[field.code] || '').trim()));
+            if (missingFields.length) warnings.push({ code: 'core_fields', fields: missingFields });
+            const overlayItems = pkg.product_overlay?.checklist_items || [];
+            if (overlayItems.some(item => !item.checked)) warnings.push({ code: 'published_documents' });
