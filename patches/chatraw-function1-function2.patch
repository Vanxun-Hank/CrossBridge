@@ -0,0 +1,19 @@
+<!DOCTYPE html>
+<html lang="en">
+<head>
+    <meta charset="UTF-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1.0">
+    <title>Official Form Viewer</title>
+    <!-- Same-origin sandboxed viewer for genuine BOCHK AcroForm PDFs. Driven only by
+         the parent workbench via a restricted postMessage protocol. -->
+    <link rel="stylesheet" href="vendor/pdfjs/web/pdf_viewer.css?v=cbdev19">
+    <link rel="stylesheet" href="official-pdf-viewer.css?v=cbdev31">
+</head>
+<body>
+    <div id="status" class="ofv-status" role="status" aria-live="polite"></div>
+    <div id="viewerContainer" class="ofv-container">
+        <div id="viewer" class="pdfViewer"></div>
+    </div>
+    <script type="module" src="official-pdf-viewer.js?v=cbdev31"></script>
+</body>
+</html>
diff --git a/backend/static/official-pdf-viewer.js b/backend/static/official-pdf-viewer.js
new file mode 100644
index 0000000..e758f62
--- /dev/null
+++ b/backend/static/official-pdf-viewer.js
@@ -0,0 +1,388 @@
+// Sandboxed viewer for genuine BOCHK official AcroForm PDFs.
+//
+// Contract with the parent workbench (same-origin only):
+//   parent -> viewer : { source:'crossbridge-doc-prep', type:'load-draft'|'export'|'print', ... }
+//   viewer -> parent : { source:'official-pdf-viewer',  type:'ready'|'draft-changed'|'error', ... }
+//
+// We render the ORIGINAL bank PDF with PDF.js form widgets (ENABLE_FORMS), keep values
+// in pdfDocument.annotationStorage, and export/print via saveDocument() — no flattening,
+// no coordinate overlays, no remote URLs. Internal annotation ids never leave the viewer;
+// only registry-known AcroForm field NAMES are sent to the parent.
+import * as pdfjsLib from "./vendor/pdfjs/legacy/build/pdf.mjs";
+import { EventBus, PDFLinkService, PDFViewer } from "./vendor/pdfjs/legacy/web/pdf_viewer.mjs";
+
+// Absolute base URL (resolved against THIS module's URL). Must be absolute so the
+// worker/cmap/font URLs resolve correctly on BOTH paths: Chromium's real module worker
+// (document-relative) AND Safari's main-thread "fake worker" which import()s workerSrc
+// relative to pdf.mjs — a relative value there doubled the path (/vendor/.../build/
+// vendor/.../build/pdf.worker.mjs -> 404) and broke the viewer in Safari.
+const VENDOR = new URL("./vendor/pdfjs/", import.meta.url).href;
+// Use PDF.js's official legacy worker so Safari gets the matching compatibility layer.
+pdfjsLib.GlobalWorkerOptions.workerSrc = VENDOR + "legacy/build/pdf.worker.mjs?v=cbdev19";
+
+const PARENT_ORIGIN = window.location.origin;
+const DRAFT_DEBOUNCE_MS = 500;
+
+const statusEl = document.getElementById("status");
+const container = document.getElementById("viewerContainer");
+
+const eventBus = new EventBus();
+const linkService = new PDFLinkService({ eventBus });
+const pdfViewer = new PDFViewer({
+    container,
+    eventBus,
+    linkService,
+    annotationMode: pdfjsLib.AnnotationMode.ENABLE_FORMS,
+});
+linkService.setViewer(pdfViewer);
+
+// Re-apply page-width scaling whenever the container gains a real (non-zero) width.
+// If pagesinit runs while the panel/iframe is momentarily 0-width (Alpine x-show layout
+// race), "page-width" computes a negative scale and pages render at 0x0 (a blank viewer
+// with no error). This observer recovers as soon as the container has a usable width, and
+// also keeps the form fit-to-width when the document panel is resized.
+const scaleObserver = new ResizeObserver(() => {
+    if (pdfDocument && container.clientWidth > 0) {
+        try {
+            pdfViewer.currentScaleValue = "page-width";
+        } catch (_) {
+            /* viewer not ready yet */
+        }
+    }
+});
+scaleObserver.observe(container);
+
+let pdfDocument = null;
+let idToName = new Map(); // annotation element id -> AcroForm field name
+let nameToIds = new Map(); // AcroForm field name -> [annotation element ids]
+let draftTimer = null;
+let activePackageId = "";
+let activeFormId = "";
+let activeLoadId = "";
+let inFlightLoadId = "";
+let loadGeneration = 0;
+
+function post(type, payload = {}) {
+    window.parent.postMessage({ source: "official-pdf-viewer", type, ...payload }, PARENT_ORIGIN);
+}
+
+function setStatus(message) {
+    statusEl.textContent = message || "";
+    statusEl.style.display = message ? "block" : "none";
+}
+
+// Resolve once the container has a real (non-zero) width. The iframe boots while its
+// parent panel is still display:none (Alpine x-show), so rendering a cached PDF can reach
+// pagesinit before layout — yielding a negative "page-width" scale and a blank page.
+// Waiting here makes the initial fit deterministic instead of relying on a later resize.
+function waitForContainerWidth() {
+    return new Promise((resolve) => {
+        let tries = 0;
+        const check = () => {
+            if (container.clientWidth > 0 || tries++ > 180) resolve();
+            else requestAnimationFrame(check);
+        };
+        check();
+    });
+}
+
+// Surface any uncaught failure to the parent (and on-screen) so a broken viewer is never
+// just a silent blank panel — important since this runs in browsers we can't all test directly.
+window.addEventListener("error", (event) => {
+    const detail = (event && (event.message || (event.error && event.error.message))) || "script error";
+    setStatus("Viewer error: " + detail);
+    post("error", { message: detail });
+});
+window.addEventListener("unhandledrejection", (event) => {
+    const reason = event && event.reason;
+    const detail = (reason && (reason.message || String(reason))) || "unhandled rejection";
+    setStatus("Viewer error: " + detail);
+    post("error", { message: detail });
+});
+
+eventBus.on("pagesinit", () => {
+    pdfViewer.currentScaleValue = "page-width";
+    // Re-apply on the next frame: on first paint the container can still be mid-layout
+    // (0-width), which yields a negative scale and a blank page. This + the ResizeObserver
+    // make the initial fit deterministic across browsers (incl. Safari).
+    requestAnimationFrame(() => {
+        if (container.clientWidth > 0) {
+            pdfViewer.currentScaleValue = "page-width";
+        }
+    });
+});
+
+async function loadDraft({ pdfUrl, values, packageId, formId, loadId }) {
+    if (typeof pdfUrl !== "string" || !pdfUrl.startsWith("/")
+        || typeof packageId !== "string" || !packageId
+        || typeof formId !== "string" || !formId
+        || typeof loadId !== "number") {
+        // Only same-origin, app-served PDF endpoints are allowed.
+        post("error", { message: "invalid pdf url" });
+        return;
+    }
+    // The parent can flush the same queued load from several lifecycle hooks. Ignore
+    // duplicates, and discard a slower previous load if the user has already selected
+    // another form.
+    if (loadId === activeLoadId || loadId === inFlightLoadId) return;
+    const generation = ++loadGeneration;
+    emitDraftChanged();
+    inFlightLoadId = loadId;
+    setStatus("Loading official form…");
+    try {
+        const response = await fetch(pdfUrl, { credentials: "same-origin" });
+        if (!response.ok) throw new Error(`PDF fetch failed (${response.status})`);
+        const data = new Uint8Array(await response.arrayBuffer());
+        const loadingTask = pdfjsLib.getDocument({
+            data,
+            cMapUrl: VENDOR + "cmaps/",
+            cMapPacked: true,
+            standardFontDataUrl: VENDOR + "standard_fonts/",
+        });
+        const nextDocument = await loadingTask.promise;
+        if (generation !== loadGeneration) {
+            await nextDocument.destroy();
+            return;
+        }
+
+        const nextIdToName = new Map();
+        const nextNameToIds = new Map();
+        const fieldObjects = (await nextDocument.getFieldObjects()) || {};
+        for (const [name, items] of Object.entries(fieldObjects)) {
+            for (const item of items) {
+                if (!item || !item.id) continue;
+                nextIdToName.set(item.id, name);
+                if (!nextNameToIds.has(name)) nextNameToIds.set(name, []);
+                nextNameToIds.get(name).push(item.id);
+            }
+        }
+
+        // Seed persisted values before widgets render so they appear pre-filled.
+        const storage = nextDocument.annotationStorage;
+        for (const [name, value] of Object.entries(values || {})) {
+            for (const id of nextNameToIds.get(name) || []) {
+                storage.setValue(id, { value });
+            }
+        }
+
+        // Render only once the container is laid out, so the initial page-width scale is
+        // computed against a real width (never a 0-width -> negative-scale -> blank page).
+        await waitForContainerWidth();
+        if (generation !== loadGeneration) {
+            await nextDocument.destroy();
+            return;
+        }
+        const previousDocument = pdfDocument;
+        pdfDocument = nextDocument;
+        idToName = nextIdToName;
+        nameToIds = nextNameToIds;
+        activePackageId = packageId;
+        activeFormId = formId;
+        activeLoadId = loadId;
+        inFlightLoadId = "";
+        linkService.setDocument(nextDocument, null);
+        pdfViewer.setDocument(nextDocument);
+        if (previousDocument && previousDocument !== nextDocument) {
+            previousDocument.destroy().catch(() => {});
+        }
+        setStatus("");
+        post("ready", { formLoaded: true, pages: nextDocument.numPages, packageId, formId, loadId });
+    } catch (error) {
+        if (generation !== loadGeneration) return;
+        inFlightLoadId = "";
+        setStatus("Could not load this form.");
+        post("error", { message: String((error && error.message) || error), packageId, formId, loadId });
+    }
+}
+
+function collectValues() {
+    if (!pdfDocument) return {};
+    // The (legacy) build's annotationStorage has no getAll(); read each known field by id
+    // via getValue(). idToName was populated from getFieldObjects() at load time.
+    const storage = pdfDocument.annotationStorage;
+    const out = {};
+    for (const [id, name] of idToName) {
+        let entry = null;
+        try {
+            entry = storage.getValue(id, {});
+        } catch (_) {
+            entry = null;
+        }
+        if (entry && typeof entry === "object" && "value" in entry) {
+            const value = entry.value;
+            if (value !== undefined && value !== null && value !== "") {
+                out[name] = value;
+            }
+        }
+    }
+    return out;
+}
+
+function emitDraftChanged() {
+    clearTimeout(draftTimer);
+    draftTimer = null;
+    if (!pdfDocument || !activePackageId || !activeFormId || !activeLoadId) return;
+    post("draft-changed", {
+        packageId: activePackageId,
+        formId: activeFormId,
+        loadId: activeLoadId,
+        values: collectValues(),
+    });
+}
+
+function scheduleDraftChanged() {
+    clearTimeout(draftTimer);
+    draftTimer = setTimeout(emitDraftChanged, DRAFT_DEBOUNCE_MS);
+}
+
+function unloadDocument() {
+    ++loadGeneration;
+    clearTimeout(draftTimer);
+    draftTimer = null;
+    inFlightLoadId = "";
+    const previousDocument = pdfDocument;
+    pdfDocument = null;
+    idToName = new Map();
+    nameToIds = new Map();
+    activePackageId = "";
+    activeFormId = "";
+    activeLoadId = "";
+    linkService.setDocument(null, null);
+    pdfViewer.setDocument(null);
+    if (previousDocument) previousDocument.destroy().catch(() => {});
+    setStatus("");
+}
+
+// Form widgets are real DOM inputs inside the annotation layer.
+container.addEventListener("input", scheduleDraftChanged, true);
+container.addEventListener("change", scheduleDraftChanged, true);
+
+function downloadBytes(bytes, filename) {
+    const blob = new Blob([bytes], { type: "application/pdf" });
+    const url = URL.createObjectURL(blob);
+    const link = document.createElement("a");
+    link.href = url;
+    link.download = filename;
+    document.body.appendChild(link);
+    link.click();
+    link.remove();
+    setTimeout(() => URL.revokeObjectURL(url), 10000);
+}
+
+async function exportPdf(filename) {
+    if (!pdfDocument) return;
+    try {
+        // saveDocument() writes annotationStorage values into the AcroForm and preserves
+        // the original encryption/permissions; it does NOT flatten the fields.
+        const bytes = await pdfDocument.saveDocument();
+        downloadBytes(bytes, filename || "bochk-official-form.pdf");
+        emitDraftChanged();
+    } catch (error) {
+        post("error", { message: String((error && error.message) || error) });
+    }
+}
+
+async function printPdf() {
+    if (!pdfDocument) return;
+    try {
+        const bytes = await pdfDocument.saveDocument();
+        const blob = new Blob([bytes], { type: "application/pdf" });
+        const url = URL.createObjectURL(blob);
+        const frame = document.createElement("iframe");
+        frame.setAttribute("aria-hidden", "true");
+        Object.assign(frame.style, {
+            position: "fixed",
+            right: "0",
+            bottom: "0",
+            width: "0",
+            height: "0",
+            border: "0",
+        });
+        frame.src = url;
+        frame.onload = () => {
+            try {
+                frame.contentWindow.focus();
+                frame.contentWindow.print();
+            } catch (_) {
+                /* user can still print from the downloaded copy */
+            }
+        };
+        document.body.appendChild(frame);
+        setTimeout(() => {
+            URL.revokeObjectURL(url);
+            frame.remove();
+        }, 60000);
+    } catch (error) {
+        post("error", { message: String((error && error.message) || error) });
+    }
+}
+
+// ---- required-field highlighting (red outline + scroll to the offending fields) ----
+function annotationElementFor(annotationId) {
+    return document.querySelector(`[data-annotation-id="${annotationId}"]`)
+        || document.querySelector(`[data-element-id="${annotationId}"]`)
+        || document.getElementById(annotationId);
+}
+
+function clearHighlights() {
+    document.querySelectorAll(".ofv-highlight").forEach((el) => el.classList.remove("ofv-highlight"));
+    document.querySelectorAll(".ofv-highlight-field").forEach((el) => el.classList.remove("ofv-highlight-field"));
+}
+
+// Highlight by AcroForm field NAME (via nameToIds → annotation id → widget DOM). The
+// annotation layer renders lazily, so retry briefly until the widgets exist; then
+// scroll the first into view.
+function highlightFields(fieldNames, attempt = 0) {
+    if (!pdfDocument || !Array.isArray(fieldNames)) return;
+    clearHighlights();
+    let first = null;
+    let count = 0;
+    for (const name of fieldNames) {
+        for (const id of nameToIds.get(name) || []) {
+            const el = annotationElementFor(id);
+            if (!el) continue;
+            el.classList.add("ofv-highlight");
+            el.querySelectorAll("input, textarea, select").forEach((f) => f.classList.add("ofv-highlight-field"));
+            if (!first) first = el;
+            count += 1;
+        }
+    }
+    if (count === 0 && attempt < 15) {
+        setTimeout(() => highlightFields(fieldNames, attempt + 1), 200);
+        return;
+    }
+    if (first) first.scrollIntoView({ behavior: "smooth", block: "center" });
+    post("highlight-applied", { count });
+}
+
+window.addEventListener("message", (event) => {
+    if (event.origin !== PARENT_ORIGIN) return;
+    const message = event.data || {};
+    if (message.source !== "crossbridge-doc-prep") return;
+    switch (message.type) {
+        case "load-draft":
+            loadDraft(message);
+            break;
+        case "flush-draft":
+            emitDraftChanged();
+            break;
+        case "unload":
+            unloadDocument();
+            break;
+        case "export":
+            exportPdf(message.filename);
+            break;
+        case "print":
+            printPdf();
+            break;
+        case "highlight-fields":
+            highlightFields(message.fieldNames);
+            break;
+        case "clear-highlights":
+            clearHighlights();
+            break;
+    }
+});
+
+// Announce readiness so the parent knows it can send load-draft.
+post("ready", { booted: true });
