+        docBlockingTargets() {
+            const forms = this.documentPreparation.package?.official_forms || [];
+            const codesFor = (item) => {
+                if (item.code === 'core_fields') return item.fields || [];
+                if (item.code === 'beneficiary_name') return ['supplier_name', 'beneficiary_account_name'];
+                if (item.code === 'invoice_payment') return ['invoice_amount', 'payment_amount', 'invoice_currency', 'payment_currency'];
+                return [item.code]; // swift_bic, charge_bearer
+            };
+            const resolveOnForms = (codes) => {
+                for (const form of forms) {
+                    const b = form.validation_bindings || {};
+                    const fieldNames = codes.map(c => b[c]).filter(Boolean);
+                    if (fieldNames.length) return { formId: form.form_id, fieldNames };
+                }
+                return null;
+            };
+            const targets = [];
+            for (const item of (this.documentTimeline.blocking || [])) {
+                if (item.code === 'published_documents') { targets.push({ code: item.code, overlay: true }); continue; }
+                const t = resolveOnForms(codesFor(item));
