+/* The old "print the workbench HTML" path is retired: official forms are printed by
+   the embedded PDF.js viewer (saveDocument() -> hidden iframe -> print), so the genuine
+   bank PDF is what reaches the printer — not a CSS rendering of the panel. */
+
+/* ---- Function 1: candidate selection toggle ----
+   "Select" is a SECONDARY outlined button: same height/radius/padding/font as the primary
+   "Prepare Documents" so the pair is aligned and balanced, but visually one tier lighter. */
+.loan-card-actions {
+    display: flex;
+    gap: 8px;
+    flex-wrap: wrap;
+    align-items: stretch;   /* both buttons take the same height */
+    margin-top: 12px;
+}
+/* Neutralize stray margins (e.g. .loan-doc-prep-btn's margin-top:14px) so the row is aligned. */
+.loan-card-actions > .loan-btn {
+    margin: 0;
+}
+.loan-btn-select {
+    display: inline-flex;
+    align-items: center;
+    justify-content: center;
+    gap: 6px;
+    color: var(--text-secondary);
+    background: var(--bg-primary);
+    border: 1px solid var(--border-color);
+    transition: color .12s ease, background .12s ease, border-color .12s ease;
+}
+.loan-btn-select i {
+    font-size: 1.05em;
+    line-height: 1;
+}
+.loan-btn-select:hover:not(:disabled) {
+    color: var(--text-primary);
+    border-color: var(--accent-color);
+    background: var(--bg-hover);
+}
+.loan-btn-select.is-selected {
+    color: var(--accent-color);
+    border-color: var(--accent-color);
+    /* subtle accent wash; falls back to bg-hover where color-mix is unsupported */
+    background: var(--bg-hover);
+    background: color-mix(in srgb, var(--accent-color) 10%, var(--bg-primary));
+    font-weight: 600;
+}
+
+/* ---- Function 1: saved-drafts list modal ---- */
+.saved-drafts-modal {
