+
+        async saveDocTemplate(templateCode) {
+            const packageId = this.documentPreparation.package?.id;
+            const template = this.documentPreparation.package?.templates
+                ?.find(item => item.code === templateCode);
+            if (!packageId || !template) return;
+            this.documentPreparation.templateSaving[templateCode] = true;
+            try {
+                const res = await fetch(`/api/crossbridge-documents/v1/packages/${packageId}/templates/${templateCode}`, {
+                    method: 'PATCH',
+                    headers: { 'Content-Type': 'application/json' },
+                    body: JSON.stringify({ content: template.content || {} })
