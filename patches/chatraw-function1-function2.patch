+
+        // ============================================================
+        // Function 1 — chat-embedded loan matching (Claude-Code style)
+        // ============================================================
+
+        // Option chips for enum slots. Tapping a chip = deterministic PATCH (no LLM),
+        // which sidesteps garbage input entirely.
+        loanChipsForField(field) {
+            if (field === 'business_scenario') {
+                return [
+                    { value: 'overseas_procurement', key: 'cbScenarioProcurement' },
+                    { value: 'cross_border_ecommerce', key: 'cbScenarioEcommerce' },
+                    { value: 'export_trade', key: 'cbScenarioExport' },
+                    { value: 'overseas_investment', key: 'cbScenarioInvestment' },
+                ];
+            }
+            if (field === 'financing_purpose') {
+                return [
+                    { value: 'procurement_payment', key: 'cbPurposeSupplier' },
+                    { value: 'stocking', key: 'cbPurposeStocking' },
+                    { value: 'order_fulfillment', key: 'cbPurposeOrder' },
+                    { value: 'working_capital', key: 'cbPurposeWorkingCapital' },
+                    { value: 'investment', key: 'cbPurposeInvestment' },
+                ];
+            }
+            return [];
+        },
+
+        loanChipLabelByValue(field, value) {
+            const chip = this.loanChipsForField(field).find(c => c.value === value);
+            return chip ? this.t(chip.key) : value;
+        },
+
+        // How many of the 4 required slots are filled (drives the progress dots).
+        loanRequiredCompletedCount() {
+            const req = ['business_scenario', 'annual_turnover_hkd', 'financing_purpose', 'requested_amount_hkd'];
+            const p = this.loanMatching.session?.draft_profile || {};
+            return req.filter(k => p[k] !== null && p[k] !== undefined && p[k] !== '').length;
+        },
+
+        // The slot currently being asked + its chips (drive the anchored composer panel).
+        loanCurrentField() {
