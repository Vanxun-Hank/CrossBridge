+@app.api_route("/api/crossbridge/{path:path}", methods=["GET", "POST", "PATCH", "DELETE"])
+async def proxy_crossbridge_business_api(path: str, request: Request):
+    """Proxy only the fixed local CrossBridge business service; callers cannot choose a target."""
+    base_url = os.environ.get("CROSSBRIDGE_BUSINESS_API_URL", "http://127.0.0.1:8081").rstrip("/")
+    target_url = f"{base_url}/crossbridge/{path}"
+    if request.url.query:
+        target_url += f"?{request.url.query}"
+    headers = {"Content-Type": request.headers.get("content-type", "application/json")}
+    try:
+        session = await get_http_session()
+        async with session.request(
+            request.method,
+            target_url,
+            data=await request.body(),
+            headers=headers,
+            timeout=aiohttp.ClientTimeout(total=30),
+        ) as resp:
+            content = await resp.read()
+            return Response(
+                content=content,
+                status_code=resp.status,
+                media_type=resp.headers.get("Content-Type", "application/json"),
+            )
+    except aiohttp.ClientError as e:
+        logger.error("CrossBridge business proxy failed: %s", e)
+        return JSONResponse(
+            {"error": "CrossBridge business service is unavailable"},
+            status_code=502,
+        )
+
+@app.api_route("/api/crossbridge-documents/{path:path}", methods=["GET", "POST", "PATCH", "DELETE"])
+async def proxy_crossbridge_documents_api(path: str, request: Request):
+    """Proxy only the fixed local CrossBridge document-preparation service (Function 2).
+
+    Parallel to the Function 1 business proxy above; callers cannot choose a target.
+    Fixed target is the F2 FastAPI service on port 8082.
+    """
+    base_url = os.environ.get("CROSSBRIDGE_DOCUMENTS_API_URL", "http://127.0.0.1:8082").rstrip("/")
+    target_url = f"{base_url}/crossbridge-documents/{path}"
+    if request.url.query:
+        target_url += f"?{request.url.query}"
+    headers = {"Content-Type": request.headers.get("content-type", "application/json")}
+    try:
+        session = await get_http_session()
+        async with session.request(
+            request.method,
+            target_url,
+            data=await request.body(),
+            headers=headers,
+            timeout=aiohttp.ClientTimeout(total=30),
+        ) as resp:
+            content = await resp.read()
+            return Response(
+                content=content,
+                status_code=resp.status,
+                media_type=resp.headers.get("Content-Type", "application/json"),
+            )
+    except aiohttp.ClientError as e:
+        logger.error("CrossBridge documents proxy failed: %s", e)
+        return JSONResponse(
+            {"error": "CrossBridge documents service is unavailable"},
+            status_code=502,
+        )
