+        },
+        loanCurrentChips() {
+            return this.loanChipsForField(this.loanCurrentField());
+        },
+
+        // Milestone artifacts go to the transcript as chat messages.
+        // The live clarification question itself lives in the anchored composer panel,
+        // so we DON'T push a chat bubble for it (that caused the duplicate-card pileup).
+        pushLoanStep() {
+            const s = this.loanMatching.session;
+            if (!s) return;
+            if (s.match_results && s.match_results.length) {
+                this.messages.push({ role: 'assistant', loanResults: s.match_results });
+                this.$nextTick(() => this.scrollToBottom());
+            } else if ((s.missing_required_fields || []).length === 0) {
+                this.messages.push({ role: 'assistant', loanDraft: true });
+                this.$nextTick(() => this.scrollToBottom());
+            }
+            // else: still collecting → the anchored panel shows the current question.
+        },
+
+        // Two-mode switch (composer): Function 5 policy Q&A  <->  Function 1 loan matching.
+        switchToPolicyMode() {
+            if (this.loanMatching.active) this.exitLoanMatching();
+        },
+        switchToLoanMode() {
+            if (!this.loanMatching.active) this.enterLoanMatching();
+        },
+
+        // Entry point used by the mode switch, the sidebar "贷款匹配" link and the in-chat CTA.
+        // Creates OR resumes the open session, then drives the flow inside the chat.
+        async enterLoanMatching(prefill = {}) {
+            // Re-entry guard: if already in loan mode with a live session, don't create/push again
+            // (prevents the duplicate "欢迎回来 + 候选方案" when CTA + mode-switch both fire).
+            if (this.loanMatching.active && this.loanMatching.session) {
+                this.activeWorkspace = 'chat';
+                return;
+            }
+            this.activeWorkspace = 'chat';
+            this.loanMatching.active = true;
+            this.loanMatching.error = '';
+            this.loanMatching.clarifierNotice = '';
+            this.loanMatching.clarifyLoading = false;
+            this.closeSidebarOnMobile();
+            try {
+                const res = await fetch('/api/crossbridge/v1/loan-matching/sessions', {
+                    method: 'POST',
+                    headers: { 'Content-Type': 'application/json' },
+                    body: JSON.stringify({ sme_id: 'demo_sme_001', prefill })
+                });
+                const data = await res.json();
+                if (!res.ok) throw new Error(data.detail || data.error || this.t('cbCreateDraftFailed'));
+                this.syncLoanMatchingSession(data);
+                const filled = this.loanRequiredCompletedCount();
+                this.messages.push({ role: 'assistant', content: filled > 0 ? this.t('cbModeResume') : this.t('cbModeEnter') });
+                this.pushLoanStep();  // pushes draft/results if already complete; else the anchored panel shows the question
+            } catch (e) {
+                this.loanMatching.active = false;
+                this.showToast(`${this.t('cbCreateDraftFailed')}: ${e.message}`, 'error');
+            }
+        },
+
+        // Leave WITHOUT discarding — the open session persists so the user can resume later.
+        exitLoanMatching() {
+            this.loanMatching.active = false;
+            this.messages.push({ role: 'assistant', content: this.t('cbModeExit') });
+            this.$nextTick(() => this.scrollToBottom());
+        },
+
+        // A free-text answer typed in the main input box while in loan mode.
+        // The user's answer is echoed to the transcript; the next question updates the
+        // anchored composer panel in place (no question-card pileup).
+        async handleLoanChatTurn(text) {
+            this.messages.push({ role: 'user', content: text });
+            this.loanMatching.clarifierNotice = '';
+            this.loanMatching.clarifyLoading = true;
+            this.$nextTick(() => this.scrollToBottom());
+            try {
+                const res = await fetch(`/api/crossbridge/v1/loan-matching/sessions/${this.loanMatching.session.id}/clarify`, {
+                    method: 'POST',
+                    headers: { 'Content-Type': 'application/json' },
+                    body: JSON.stringify({ message: text })
+                });
+                const data = await res.json();
+                if (!res.ok) throw new Error(data.detail || this.t('cbClarifyFailed'));
+                this.syncLoanMatchingSession(data);
+                if (data.clarifier_mode === 'needs_manual') this.loanMatching.clarifierNotice = this.t('cbNeedsManual');
+                else if (data.clarifier_mode === 'no_progress') this.loanMatching.clarifierNotice = this.t('cbNoProgress');
+                else if (data.clarifier_mode === 'manual_fallback') this.loanMatching.clarifierNotice = this.t('cbClarifierFallback');
+                this.pushLoanStep();
+            } catch (e) {
+                this.showToast(`${this.t('cbClarifyFailed')}: ${e.message}`, 'error');
+            } finally {
+                this.loanMatching.clarifyLoading = false;
+            }
+        },
+
+        // A chip tapped in the anchored clarification panel.
+        async pickLoanChip(field, value) {
+            if (!field || this.loanMatching.clarifyLoading) return;
+            this.messages.push({ role: 'user', content: this.loanChipLabelByValue(field, value) });
+            this.loanMatching.clarifierNotice = '';
+            this.loanMatching.clarifyLoading = true;
+            this.$nextTick(() => this.scrollToBottom());
+            try {
+                const res = await fetch(`/api/crossbridge/v1/loan-matching/sessions/${this.loanMatching.session.id}/draft`, {
+                    method: 'PATCH',
+                    headers: { 'Content-Type': 'application/json' },
+                    body: JSON.stringify({ updates: { [field]: value } })
+                });
+                const data = await res.json();
+                if (!res.ok) throw new Error(data.detail || this.t('cbDraftSaveFailed'));
+                this.syncLoanMatchingSession(data);
+                this.pushLoanStep();
+            } catch (e) {
+                this.showToast(`${this.t('cbDraftSaveFailed')}: ${e.message}`, 'error');
