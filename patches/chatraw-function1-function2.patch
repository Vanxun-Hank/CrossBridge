+@app.post("/api/chats/{chat_id}/messages")
+async def create_card_message(chat_id: str, request: Request):
+    """Persist a UI-card message (e.g. loan draft / candidate plans / CTA).
+
+    Card messages carry their render data in `metadata` (a JSON object) and usually
+    have empty content; they are returned by GET for rehydration but excluded from the
+    model history (see `_is_card_only`)."""
+    try:
+        body = await request.json()
+    except Exception:
+        body = {}
+    role = body.get("role", "assistant") or "assistant"
+    content = body.get("content", "") or ""
+    metadata = body.get("metadata")
+    metadata_str = json.dumps(metadata, ensure_ascii=False) if metadata is not None else None
+    msg = db.add_message(chat_id, role, content, metadata_str)
+    return msg.model_dump()
+
