+            if (['overseas_procurement', 'cross_border_ecommerce'].includes(f1Scenario)
+                && scenarios.includes('import_payment')) {
+                return 'import_payment';
+            }
+            if (f1Scenario === 'export_trade' && scenarios.includes('export_fulfillment')) {
