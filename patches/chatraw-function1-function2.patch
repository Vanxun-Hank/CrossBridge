+}
+
+.thinking-toggle.active {
+    color: var(--text-primary);
+}
+
+.thinking-slider {
+    display: block;
+    width: 28px;
+    height: 14px;
+    min-width: 28px;
+    min-height: 14px;
+    background: var(--bg-tertiary);
+    border-radius: 7px;
+    position: relative;
+    transition: background 0.2s ease;
