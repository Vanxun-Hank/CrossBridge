+    background: var(--bg-secondary);
+    animation: loan-ask-in 200ms ease;
+}
+@keyframes loan-ask-in {
+    from { opacity: 0; transform: translateY(4px); }
+    to   { opacity: 1; transform: translateY(0); }
+}
+.loan-ask-top {
+    display: flex;
+    align-items: center;
+    gap: 10px;
+    margin-bottom: 8px;
+}
+.loan-ask-dots { display: inline-flex; gap: 5px; }
+.loan-ask-dot {
+    width: 7px;
+    height: 7px;
+    border-radius: var(--radius-full);
+    background: var(--bg-tertiary);
+    box-shadow: inset 0 0 0 1px var(--border-color);
+    transition: background 160ms ease;
+}
+.loan-ask-dot.done {
+    background: var(--accent-color);
+    box-shadow: none;
+}
+.loan-ask-count {
+    color: var(--text-secondary);
+    font-size: 11px;
+    letter-spacing: 0.02em;
+}
+.loan-ask-q {
+    color: var(--text-primary);
+    font-size: var(--text-base);
+    font-weight: 500;
+    line-height: 1.5;
+}
+.loan-ask-chips {
+    display: flex;
+    flex-wrap: wrap;
+    gap: 8px;
+    margin-top: 12px;
+}
+.loan-ask-hint {
+    margin-top: 10px;
+    color: var(--text-muted);
+    font-size: var(--text-xs);
+    line-height: 1.5;
+}
+.loan-ask-warn {
+    padding: 8px 10px;
+    border-radius: var(--radius-sm);
+    background: var(--bg-tertiary);
+    color: var(--text-secondary);
